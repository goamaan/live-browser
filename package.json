{
  "name": "live-browser-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Live-first browser automation with raw CDP attach and agent-friendly commands",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "bun ./scripts/clean.mjs && tsc -b && bun ./scripts/build-public-package.mjs",
    "build:force": "bun ./scripts/clean.mjs && tsc -b --force && bun ./scripts/build-public-package.mjs",
    "clean": "bun ./scripts/clean.mjs",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "consumer:smoke": "bun ./scripts/consumer-smoke.mjs",
    "docs:generate": "bun ./scripts/generate-docs.mjs",
    "docs:check": "bun ./scripts/generate-docs.mjs --check",
    "lint": "eslint .",
    "pack:check": "bun ./scripts/pack-check.mjs",
    "playwright:install": "bun ./scripts/install-playwright.mjs",
    "release:check": "bun run pack:check && bun run consumer:smoke && bun ./scripts/release-check.mjs",
    "skill:check": "bun ./scripts/sync-skill.mjs --check",
    "skill:sync": "bun ./scripts/sync-skill.mjs",
    "skill:validate": "bun ./scripts/skill-validate.mjs",
    "smoke:managed": "bun ./scripts/smoke-managed.mjs",
    "test": "vitest run --config ./packages/core/vitest.config.ts",
    "typecheck": "tsc -b --pretty false"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "esbuild": "^0.25.9",
    "eslint": "^9.22.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
